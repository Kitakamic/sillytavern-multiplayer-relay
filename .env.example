# Used by the standalone (VPS) shell and docker compose only.
# The local shell (start-relay.bat / npm run dev) ignores this file and
# generates its own creator key into data/local-relay-state.json.
HOST=0.0.0.0
PORT=3001
RELAY_CREATOR_KEY=replace-with-a-long-random-secret
MAX_ROOM_MEMBERS=6
ROOM_TTL_HOURS=168
INVITE_TTL_HOURS=24
ASSET_TTL_HOURS=24
# Shown by /health. Set RELAY_COMMIT during each deployment, for example to
# the short Git SHA used to build the running image. RELAY_VERSION defaults
# to package.json, so only set it when a deployment needs an explicit override.
# RELAY_VERSION=0.1.1
RELAY_COMMIT=unknown
RELAY_DOMAIN=relay.example.com
