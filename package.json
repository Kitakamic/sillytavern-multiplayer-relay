{
  "name": "sillytavern-multiplayer-relay",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Private WSS relay for SillyTavern Multiplayer",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "dev:standalone": "tsx watch src/standalone.ts",
    "start": "node dist/standalone.js",
    "start:local": "node dist/local.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:guard",
    "test:guard": "tsx scripts/room-guard.test.ts",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
